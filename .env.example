# Local template. Copy this file to .env and fill local-only values.
# Do not commit .env. In real environments, inject these values from a secret manager
# such as Azure Key Vault, AWS Secrets Manager, HashiCorp Vault, Kubernetes Secrets,
# Docker Secrets or GitHub Actions Secrets.

GUBEE_SECURITY_USER=change-me-api-user
GUBEE_SECURITY_PASSWORD=change-me-api-password

GUBEE_MYSQL_HOST=localhost
GUBEE_MYSQL_PORT=3307
GUBEE_MYSQL_DATABASE=gubee_stock
GUBEE_MYSQL_USER=change-me-mysql-user
GUBEE_MYSQL_PASSWORD=change-me-mysql-password
GUBEE_MYSQL_ROOT_PASSWORD=change-me-mysql-root-password

GUBEE_KAFKA_BOOTSTRAP_SERVERS=localhost:9092
